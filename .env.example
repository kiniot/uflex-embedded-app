# Copy this file to .env and fill in real values for the esp32_hw target.
# .env is git-ignored; never commit real credentials.
# Used by scripts/build_hw.sh to set PlatformIO build flags via ${sysenv.*}.

UFLEX_WIFI_SSID=YOUR_WIFI_SSID
UFLEX_WIFI_PASSWORD=YOUR_WIFI_PASSWORD
UFLEX_EDGE_HOST=192.168.1.100
UFLEX_DEVICE_API_KEY=YOUR_DEVICE_API_KEY
